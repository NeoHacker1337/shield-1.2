<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="#1B263B">

    <!-- Title Text -->
    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="App Locked"
        android:textSize="24sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <!-- Description Text -->
    <TextView
        android:id="@+id/descriptionText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enter your app lock password to unlock this app"
        android:textSize="16sp"
        android:textColor="#B0BEC5"
        android:gravity="center"
        android:layout_marginBottom="24dp" />

    <!-- Password Input -->
    <EditText
        android:id="@+id/passwordInput"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="Enter password"
        android:textColorHint="#757575"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:inputType="textPassword"
        android:background="@drawable/password_input_background"
        android:padding="12dp"
        android:layout_marginBottom="24dp"
        android:maxLines="1"
        android:singleLine="true" />

    <!-- Button Container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <!-- Cancel Button -->
        <Button
            android:id="@+id/cancelButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Cancel"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:background="@drawable/cancel_button_background"
            android:layout_marginEnd="8dp"
            android:textAllCaps="false" />

        <!-- Unlock Button -->
        <Button
            android:id="@+id/unlockButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Unlock"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:background="@drawable/unlock_button_background"
            android:layout_marginStart="8dp"
            android:textAllCaps="false" />

    </LinearLayout>

</LinearLayout>
